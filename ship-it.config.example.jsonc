// Example ship-it.config for Sanum (the worked example behind CONTRACTS.md).
// init produces one of these per project. JSON or JSONC; comments are for the
// example only. init writes it to .claude/ship-it/config.json (repo root or
// .claude/ship-it.config.json also work as loader fallbacks).
{
  "repo": {
    "mainBranch": "main",
    // merge is the stacking-friendly choice: it preserves the base branch's commits so
    // stacked PRs retarget cleanly, whereas squash rewrites them and strands the child.
    // Set this to how the repo actually merges.
    "mergeStrategy": "merge"
    // slug auto-detected via `gh repo view`
  },

  "source": {
    "default": "tracker",
    "tracker": {
      "type": "linear",          // built-in linear adapter (via the Linear MCP)
      "project": "Sanum",
      "team": "Fractally",
      "idPrefix": "FRA-"
    }
  },

  // Injected into every worker prompt. @AGENTS.md = read the repo's AGENTS.md verbatim.
  "houseRules": "@AGENTS.md",

  "safety": [
    "Code-only verification: never start a dev server (the human does visual/clinical QA).",
    "Never read personal health data: no screenshots of readings, no SQL value probes.",
    "No em dashes; no AI attribution in commits or PRs.",
    "This is NOT the Next.js you know: read node_modules/next/dist/docs/ before touching a Next API."
  ],

  // Run inside the worktree after a change. {changedFiles} is substituted.
  "verify": [
    "node_modules/.bin/biome check {changedFiles}",
    "node_modules/.bin/tsc --noEmit"
  ],

  "worktree": {
    "enabled": true,
    "root": ".claude/worktrees",
    // project-supplied (lives in the repo, not the plugin, since Sanum's prep is project-specific):
    // real offline install + links the Tauri sidecar resources. {wt} and {main} are substituted.
    "prepare": ".claude/ship-it/prepare-worktree.sh {wt} {main}",
    // human run/QA caveats, surfaced at the Phase 8 handoff (NOT worker rails, which go in safety):
    "qaNotes": [
      "Only one app instance at a time: shared SANUM_DATA_DIR and DuckDB is single-writer. Quit other instances and keep port 3000 free before running a worktree."
    ]
  },

  "concurrency": { "maxLanes": 4 },

  // Per-issue planning: a concurrent, read-only plan per work-unit, gated at the Phase 3
  // checkpoint, posted back to the tracker, and implemented against. Adaptive depth: thin
  // tickets get a fuller plan, trivial ones stay terse.
  "planning": {
    "enabled": true,
    "postBack": true,    // post the approved plan back to the Linear issue (idempotent)
    "depth": "adaptive"  // adaptive | light | full
  },

  // Parallel reviewer fan-out over each diff (read-only). Default + extras.
  "review": {
    "reviewers": [
      {
        "name": "pr-review",
        "kind": "agent",
        "ref": "pr-review-toolkit:code-reviewer",
        "install": "pr-review-toolkit@claude-plugins-official"
      },
      {
        "name": "vercel-react-best-practices",
        "kind": "skill",
        "ref": "vercel-react-best-practices",
        "scope": "diff-with-base",
        // Vercel Engineering's React/Next.js best-practices ruleset (40+ rules, 8 categories); applies all its rules to the diff, not just perf.
        "install": "npx skills add vercel-labs/agent-skills"
      }
    ],
    "applyWarranted": true   // batch applies warranted items; standalone reports
  },

  "ci": { "watch": true, "fixAttempts": 2 },

  // Parallel doc-job fan-out. Each owns a different file, so they run together.
  "docs": {
    "enabled": true,
    "jobs": [
      { "name": "openspec",     "mechanic": "author-reconcile", "ref": "openspec-propose", "target": "openspec/",     "appliesWhen": "capability" },
      { "name": "design",       "mechanic": "curate-serial",    "ref": "impeccable",       "target": "DESIGN.md",     "appliesWhen": "design" },
      // ARCHITECTURE.md keeper (the parked follow-up): generated curate-serial job, classify per-issue, write once.
      { "name": "architecture", "mechanic": "curate-serial",    "ref": "doc-architecture",         "target": "ARCHITECTURE.md", "appliesWhen": "architecture" },
      { "name": "graphify",     "mechanic": "regenerate",       "ref": "graphify update .", "target": "graphify-out/" }
    ]
  },

  "prTemplate": {
    "sections": ["Summary", "Linear", "Verification"],
    "verification": "two-part: (1) automated checks run with results; (2) a GitHub checkbox list of concrete visual/clinical QA steps with exact commands/queries. Never 'left to the reviewer'. No personal health values in the PR."
  }
}
